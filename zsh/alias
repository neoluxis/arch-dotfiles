alias ll='ls -lah'
alias cls='clear'
alias fetch='neofetch | lolcat'

alias paclean='yay -Scc && paru -Scc'
alias pacleanne='yay $(yay -Qtdq) -Rddscun && paru $(paru -Qtdq) -Rddscun'
alias pacleanna='paclean; pacleanne || echo No Package got to clean'

alias ccpfetch='neofetch --source ~/.config/neofetch/ccp_ascii | lolcat'
alias ccp='neofetch --source ~/.config/neofetch/ccp_ascii'
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias open='xdg-open'

alias activ='conda activate'
alias deact='conda deactivate'

alias zhb="z hexo_blog"
alias zbt="z blog-texts"

alias dls='distrobox ls'
alias den='distrobox enter'
alias dstp='distrobox stop'
alias drm='distrobox rm'

